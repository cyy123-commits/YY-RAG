# ============================================================
# 环境变量配置模板
# 使用说明：复制此文件为 .env 并填入真实值
#   cp .env.example .env
# ⚠️ .env 包含敏感信息，已被 .gitignore 排除，禁止提交到 Git
# ============================================================

# ===================== MinerU PDF 解析服务 =====================
# 模型源：modelscope（魔搭社区）
MINERU_MODEL_SOURCE=modelscope
MODELSCOPE_OFFLINE=1
# 模型缓存目录（根据实际路径修改）
MODELSCOPE_CACHE=D:/ai_models/modelscope_cache
HF_HOME=D:/ai_models/huggingface_cache
MD_ROOT_DIR=./temp-files/
# MinerU API 配置
# 申请地址：https://mineru.net
MINERU_API_TOKEN=<your-mineru-jwt-token>
MINERU_BASE_URL=https://mineru.net/api/v4

# ===================== 大模型 (LLM) 配置 =====================
# api_key 申请：https://bailian.console.aliyun.com
# 文档：https://help.aliyun.com/zh/model-studio
LLM_DEFAULT_MODEL=qwen-flash
VL_MODEL=qwen3-vl-flash
OPENAI_API_KEY=<your-dashscope-api-key>
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_DEFAULT_TEMPERATURE=0.1

# ===================== Embedding 向量模型配置 =====================
# 模型下载：魔搭 modelscope 下载 BAAI/bge-m3 到本地
BGE_M3_PATH=C:/ai_models/modelscope_cache/models/BAAI/bge-m3
BGE_M3=BAAI/bge-m3
# 设备：cuda:0 或 cpu
BGE_DEVICE=cuda:0
# GPU 下开启 FP16，CPU 下设为 0
BGE_FP16=1
ITEM_NAME_DIAG=1

# ===================== Milvus 向量数据库配置 =====================
MILVUS_URL=http://<your-milvus-host>:19530
CHUNKS_COLLECTION=kb_chunks
ITEM_NAME_COLLECTION=kb_item_names
EMBEDDING_DIM=1024

# ===================== MongoDB 配置 =====================
MONGO_URL=mongodb://<your-mongo-host>:27017
MONGO_DB_NAME=kb002

# ===================== MinIO 对象存储配置 =====================
MINIO_ENDPOINT=<your-minio-host>:9000
MINIO_ACCESS_KEY=<your-minio-access-key>
MINIO_SECRET_KEY=<your-minio-secret-key>
MINIO_BUCKET_NAME=knowledge-base-files
MINIO_IMG_DIR=/upload-images
MINIO_SECURE=False

# ===================== Reranker 重排序模型配置 =====================
BGE_RERANKER_LARGE=C:/ai_models/modelscope_cache/models/rerank/BAAI/bge-reranker-large
BGE_RERANKER_DEVICE=cuda:0
BGE_RERANKER_FP16=1

# ===================== MCP 网络搜索配置 =====================
MCP_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/mcp

# ===================== 日志配置 =====================
LOG_CONSOLE_ENABLE=True
LOG_CONSOLE_LEVEL=INFO
LOG_FILE_ENABLE=True
LOG_FILE_LEVEL=INFO
LOG_FILE_RETENTION=7 days
